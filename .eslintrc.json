{
  "root": true,
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": 12,
    "sourceType": "module"
  },
  "plugins": [
    "@typescript-eslint"
  ],
  "rules": {
    "@typescript-eslint/naming-convention": "off",
    "@typescript-eslint/semi": "warn",
    "curly": "warn",
    "eqeqeq": "warn",
    "no-throw-literal": "warn",
    "semi": "warn"
  },
  "ignorePatterns": [
    "out",
    "dist",
    "**/*.d.ts",
    "*.config.js",
    "**/*.js"
  ],
  "overrides": [
    {
      "files":["src/fetch-client-core/**/*.ts"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns":[
              "**/fetch-client-vscode/**",
              "**/fetch-client-cli/**"
            ]
          }
        ]
      }
    },
    {
      "files":["src/fetch-client-cli/**/*.ts"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns":[
              "**/fetch-client-vscode/**"
            ]
          }
        ]
      }
    },
    {
      "files":["src/fetch-client-vscode/**/*.ts"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns":[
              "**/fetch-client-cli/**"
            ]
          }
        ]
      }
    }
  ]
}
