# Always use HTTPS
registry=https://registry.npmjs.org/

# Enforce SSL certificate validation
strict-ssl=true

# Do not send authentication tokens to unrelated registries
always-auth=false

# Prefer online metadata checks
prefer-online=true

# Verify package integrity using lockfile hashes
package-lock=true

# Do not allow unsafe permissions when running as root
unsafe-perm=false

# Reduce noisy output
fund=false
audit=true

# Use exact versions when installing
save-exact=true

# minimum of release age is 7 days
min-release-age=7

# verify the signature
verify-signatures=true