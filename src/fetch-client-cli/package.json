{
  "name": "@fetch-client/cli",
  "version": "1.0.0",
  "description": "CLI tool to run and manage Fetch Client API collections from the terminal",
  "license": "MIT",
  "author": "Ganesan Chandran",
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "fc-cli": "./cli.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Ganesan-Chandran/vscode-fetch-client.git"
  },
  "keywords": [
    "fetch",
    "fetch client",
    "fetch-client",
    "fetch client cli",
    "api",
    "rest",
    "cli",
    "postman",
    "thunder-client"
  ],
  "scripts": {
    "build": "npx webpack --mode production --config ../../webpack.cli.config.js",
    "build:dev": "npx webpack --mode development --config ../../webpack.cli.config.js",
    "watch": "npx webpack --mode development --watch --config ../../webpack.cli.config.js"
  },
  "dependencies": {
    "axios": "1.17.0",
    "aws4": "1.13.2",
    "form-data": "4.0.6",
    "lokijs": "1.5.12",
    "uuid": "14.0.0"
  },
  "devDependencies": {
    "@types/vscode": "1.118.0",
    "@types/aws4": "1.11.6",
    "@types/lokijs": "1.5.14",
    "@types/node": "22.19.19",
    "fast-xml-parser": "5.8.0",
    "ts-loader": "9.5.7",
    "typescript": "4.9.5",
    "webpack": "5.107.2",
    "webpack-cli": "5.1.4"
  }
}